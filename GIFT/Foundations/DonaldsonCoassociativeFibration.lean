/-- Explicit Fano-oriented meridian relation model.

The 14 meridians are the 7 Fano lines doubled by orientation.  The fixed-block
relation matrix is audited externally by
`scripts/donaldson_fano_link_model.py`:

* 7 orientation-pair relations;
* 4 projective-coordinate Fano relations;
* combined rank `11 = D_bulk`;
* fixed quotient rank `3 = N_gen`.

The moved block has no relation rows; after the rank-one monodromy `d0` image,
it contributes `14 - 1 = 13 = alpha_sum`.
-/
structure DonaldsonFanoOrientedMeridianLinkModel where
  fanoLineCount : Nat
  orientedMeridianCount : Nat
  orientationPairRelationRank : Nat
  fanoProjectiveCoordinateRelationRank : Nat
  fixedRelationMatrixRank : Nat
  fixedQuotientRank : Nat
  movedRelationMatrixRank : Nat
  movedQuotientRank : Nat
  relationMatrixRankAudited : Bool
  actualDonaldsonDiscriminantLinkCertified : Bool
  deriving DecidableEq, Repr

def DonaldsonFanoOrientedMeridianLinkModel.fixedRelationRankFromRows
    (M : DonaldsonFanoOrientedMeridianLinkModel) : Nat :=
  M.orientationPairRelationRank + M.fanoProjectiveCoordinateRelationRank

def DonaldsonFanoOrientedMeridianLinkModel.fixedQuotientRankFromRows
    (M : DonaldsonFanoOrientedMeridianLinkModel) : Nat :=
  M.orientedMeridianCount - M.fixedRelationRankFromRows

def DonaldsonFanoOrientedMeridianLinkModel.movedQuotientRankFromRows
    (M : DonaldsonFanoOrientedMeridianLinkModel) : Nat :=
  M.orientedMeridianCount - 1 - M.movedRelationMatrixRank

def DonaldsonFanoOrientedMeridianLinkModel.twistedH1Dimension
    (M : DonaldsonFanoOrientedMeridianLinkModel) : Nat :=
  rankOneDonaldsonFixedBlockRank * M.fixedQuotientRank +
    rankOneDonaldsonMovedBlockRank * M.movedQuotientRank

def DonaldsonFanoOrientedMeridianLinkModel.predictedB3
    (M : DonaldsonFanoOrientedMeridianLinkModel) : Nat :=
  1 + M.twistedH1Dimension

def currentDonaldsonFanoOrientedMeridianLinkModel :
