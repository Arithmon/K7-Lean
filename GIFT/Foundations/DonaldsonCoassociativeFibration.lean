    currentDonaldsonTwistedH1LockStatus.linkRelationGeometryCertified = false := by
  native_decide

def rankOneDonaldsonFixedBlockRank : Nat := k3SecondCohomologyRank - 1
def rankOneDonaldsonMovedBlockRank : Nat := 1

/-- Rank of a relation map compatible with a single rank-one reflection.

Once the Donaldson monodromy is genuinely rank-one, the K3 cohomology local
system splits as a `21`-dimensional fixed block plus a `1`-dimensional moved
block.  Fox/Jacobian relation ranks are therefore not arbitrary: they have the
form `21*a + b`.
-/
def rankOneFoxRelationRank
    (fixedRelationMatrixRank movedRelationMatrixRank : Nat) : Nat :=
  rankOneDonaldsonFixedBlockRank * fixedRelationMatrixRank +
    rankOneDonaldsonMovedBlockRank * movedRelationMatrixRank

def rankOneFoxRelationRanksForMeridianCount (meridianCount : Nat) : List Nat :=
  (List.range (meridianCount + 1)).flatMap
    (fun fixedRank =>
      (List.range (meridianCount + 1)).map
        (fun movedRank => rankOneFoxRelationRank fixedRank movedRank))

theorem rank_one_fox_four_meridian_ranks_reject_naive_rank_11 :
    (rankOneFoxRelationRanksForMeridianCount 4).contains 11 = false := by
  native_decide

/-- A block-compatible relation profile for the rank-one Donaldson local system. -/
structure DonaldsonRankOneFoxRelationProfile where
  meridianCount : Nat
  fixedBlockRank : Nat
  movedBlockRank : Nat
  d0Rank : Nat
  fixedRelationMatrixRank : Nat
  movedRelationMatrixRank : Nat
  deriving DecidableEq, Repr

def DonaldsonRankOneFoxRelationProfile.localSystemRank
    (P : DonaldsonRankOneFoxRelationProfile) : Nat :=
  P.fixedBlockRank + P.movedBlockRank

def DonaldsonRankOneFoxRelationProfile.relationRank
    (P : DonaldsonRankOneFoxRelationProfile) : Nat :=
  P.fixedBlockRank * P.fixedRelationMatrixRank +
    P.movedBlockRank * P.movedRelationMatrixRank

def DonaldsonRankOneFoxRelationProfile.twistedH1Dimension
    (P : DonaldsonRankOneFoxRelationProfile) : Nat :=
  P.meridianCount * P.localSystemRank - P.d0Rank - P.relationRank

def DonaldsonRankOneFoxRelationProfile.predictedB3
    (P : DonaldsonRankOneFoxRelationProfile) : Nat :=
  1 + P.twistedH1Dimension

def rankOneFoxRelationProfile
    (meridianCount fixedRelationMatrixRank movedRelationMatrixRank : Nat) :
    DonaldsonRankOneFoxRelationProfile where
  meridianCount := meridianCount
  fixedBlockRank := rankOneDonaldsonFixedBlockRank
  movedBlockRank := rankOneDonaldsonMovedBlockRank
  d0Rank := 1
  fixedRelationMatrixRank := fixedRelationMatrixRank
  movedRelationMatrixRank := movedRelationMatrixRank

def rankOneFoxTargetProfilesBelow14 :
    List DonaldsonRankOneFoxRelationProfile :=
  (List.range 13).flatMap
    (fun index =>
      let meridianCount := index + 1
      (List.range (meridianCount + 1)).flatMap
        (fun fixedRank =>
          (List.range (meridianCount + 1)).filterMap
            (fun movedRank =>
              let P := rankOneFoxRelationProfile meridianCount fixedRank movedRank
              if P.twistedH1Dimension == targetDonaldsonTwistedH1Dimension then
                some P
              else
                none)))

def rankOneFoxTargetProfilesUpTo20 :
    List DonaldsonRankOneFoxRelationProfile :=
  (List.range 20).flatMap
    (fun index =>
      let meridianCount := index + 1
      (List.range (meridianCount + 1)).flatMap
        (fun fixedRank =>
          (List.range (meridianCount + 1)).filterMap
            (fun movedRank =>
              let P := rankOneFoxRelationProfile meridianCount fixedRank movedRank
              if P.twistedH1Dimension == targetDonaldsonTwistedH1Dimension then
                some P
              else
                none)))

def minimalRankOneFoxTargetProfile : DonaldsonRankOneFoxRelationProfile :=
  rankOneFoxRelationProfile 14 11 0

theorem rank_one_fox_relation_profiles_force_at_least_14_meridians :
    rankOneFoxTargetProfilesBelow14 = [] /\
    rankOneFoxTargetProfilesUpTo20.head? = some minimalRankOneFoxTargetProfile /\
    rankOneFoxTargetProfilesUpTo20.length = 7 /\
    minimalRankOneFoxTargetProfile.relationRank = 231 /\
    minimalRankOneFoxTargetProfile.twistedH1Dimension =
      targetDonaldsonTwistedH1Dimension /\
    minimalRankOneFoxTargetProfile.predictedB3 = GIFT.Core.b3 := by
  native_decide

