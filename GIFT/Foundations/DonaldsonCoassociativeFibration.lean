    DonaldsonTwistedH1LockStatus where
  targetTwistedH1 := targetDonaldsonTwistedH1Dimension
  freeMeridianScreenHitsTarget := false
  firstMeridianCountAboveTarget := 4
  freeDimensionAtFirstAboveTarget := 87
  requiredRelationRankAtFirstAboveTarget := 11
  algebraicRelationModelHitsTarget := true
  linkRelationGeometryCertified := false

theorem current_donaldson_twisted_h1_lock_status_certificate :
    currentDonaldsonTwistedH1LockStatus.targetTwistedH1 = 76 /\
    currentDonaldsonTwistedH1LockStatus.freeMeridianScreenHitsTarget = false /\
    currentDonaldsonTwistedH1LockStatus.firstMeridianCountAboveTarget = 4 /\
    currentDonaldsonTwistedH1LockStatus.freeDimensionAtFirstAboveTarget = 87 /\
