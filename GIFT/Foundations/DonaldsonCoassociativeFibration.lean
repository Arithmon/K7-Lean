def DonaldsonSpectralAdiabaticEvidence.dimensionClose
    (E : DonaldsonSpectralAdiabaticEvidence) : Bool :=
  decide (E.effectiveDimensionMilli + 100 >= E.expectedDimensionMilli /\
    E.effectiveDimensionMilli <= E.expectedDimensionMilli + 100)

def DonaldsonSpectralAdiabaticEvidence.poissonBeatsGOE
    (E : DonaldsonSpectralAdiabaticEvidence) : Bool :=
  decide (E.poissonChi2Milli < E.goeChi2Milli)

