/-- Strict-containment check for one box (all 7 components must
    satisfy `X_lo < K_lo` AND `K_hi < X_hi`). -/
@[inline] def boxStrictContained (box : Array (Int × Int × Int × Int)) : Bool :=
  box.all (fun p =>
    let xlo := p.fst
    let xhi := p.snd.fst
    let klo := p.snd.snd.fst
    let khi := p.snd.snd.snd
    (xlo < klo) && (khi < xhi))

/-- Per-chunk aggregate Boolean. -/
@[inline] def chunkStrictContained (chunk : Array (Array (Int × Int × Int × Int))) : Bool :=
  chunk.all boxStrictContained

