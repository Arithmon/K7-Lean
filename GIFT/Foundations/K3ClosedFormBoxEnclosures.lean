/-- Concatenated full enclosures array. -/
def enclosures : Array (Int × Int) := chunk_0 ++ chunk_1 ++ chunk_2 ++ chunk_3 ++ chunk_4


/-- Per-box envelope squared : `max((lo - c)², (hi - c)²)`. -/
@[inline] def uOf (p : Int × Int) : Int :=
  let a := p.fst - c_int
  let b := p.snd - c_int
  let aa := a * a
  let bb := b * b
  if aa < bb then bb else aa

/-- Aggregated envelope numerator `S = Σ_n uOf enclosures[n]`. -/
def S_num : Int := enclosures.foldl (fun acc p => acc + uOf p) 0

/-- Tidy β bound numerator (β = 1321/10000000). -/
def beta_num : Int := 1321

/-- Tidy β bound denominator (β denominator = 10^7). -/
def beta_den : Int := 10000000

/-- Cardinal cast `(N - 1 : Int) = 3999`. -/
def N_minus_one : Int := 3999

/-- Cardinal cast `D_lean² = (10^10)² = 10^20`. -/
def D_sq : Int := D_lean * D_lean

/-- **Key theorem (Plan A P0).**  The Lean-recomputed envelope sum is
    bounded above (cross-multiplied form) by `β · (N-1) · D²`, i.e.
    `S_num / ((N-1) · D²) ≤ β_num / β_den`. -/
theorem variance_envelope_bound :
    S_num * beta_den ≤ beta_num * N_minus_one * D_sq := by
  native_decide

/-- **Target met.** `β = β_num / β_den < 10⁻³` (cross-multiplied form). -/
theorem beta_below_target : beta_num * 1000 < beta_den := by
  native_decide

/-- Aggregate certificate exposing N, denominators, and the two
    `native_decide` integer checks. -/
theorem k3_box_enclosures_certificate :
    (S_num * beta_den ≤ beta_num * N_minus_one * D_sq) ∧
    (beta_num * 1000 < beta_den) := by
  refine ⟨?_, ?_⟩
  all_goals native_decide

end GIFT.Foundations.K3ClosedFormBoxEnclosures
